<IfModule mod_rewrite.c>
    RewriteEngine On
    DirectoryIndex index.php

    # Se o arquivo ou diretório solicitado fisicamente existir, acesse diretamente
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Caso contrário, redirecione tudo para o Front Controller index.php
    RewriteRule ^ index.php [L,QSA]
</IfModule>
